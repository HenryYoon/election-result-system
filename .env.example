# =============================================
# 선거 설정
# =============================================

# 선거 ID (본선거: 0020260603 / 테스트: 0020250603)
ELECTION_ID=0020260603

# 수집 일차 (1일차: 1, 2일차: 2)
DATE_CODE=1

# 테스트 모드 (1: 활성화, 0: 비활성화)
# 활성화 시 10분 간격으로 1시간씩 누적 시뮬레이션
TEST_MODE=0

# =============================================
# 구글 드라이브 (검수 이미지 소스)
# =============================================

# 서비스 계정 JSON 파일 경로 또는 base64 인코딩된 JSON 문자열
GOOGLE_SERVICE_ACCOUNT_JSON=

# 계수표 이미지가 업로드되는 드라이브 폴더 ID
# drive.google.com/drive/folders/{FOLDER_ID}
DRIVE_FOLDER_ID=

# 드라이브 감시 폴링 간격 (분 단위, 기본: 60)
DRIVE_POLL_INTERVAL=60

# 백업 대상 드라이브 폴더 ID (data/ 전체를 크롤링 사이클마다 증분 백업)
# 비워두면 백업 비활성. 서비스 계정 이메일을 이 폴더에 '편집자'로 공유해야 함
BACKUP_DRIVE_FOLDER_ID=

# =============================================
# 크롤러
# =============================================

# 병렬 크롤링 스레드 수
CRAWLER_THREADS=8
