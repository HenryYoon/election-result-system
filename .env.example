# =============================================
# 구글 API
# =============================================

# 서비스 계정 JSON 파일 경로 또는 base64 인코딩된 JSON 문자열
# 예시 (파일 경로): /app/service_account.json
# 예시 (base64): eyJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsIC...
GOOGLE_SERVICE_ACCOUNT_JSON=

# 결과 집계 스프레드시트 ID
